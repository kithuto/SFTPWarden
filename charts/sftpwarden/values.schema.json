{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "runtime": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1,
          "description": "Reserved for future multi-node support. SFTPWarden v1.2 supports replicas: 1 only."
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        }
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "dsnSecretName": {
          "type": ["string", "null"]
        },
        "dsnSecretKey": {
          "type": "string",
          "minLength": 1
        },
        "createDsnSecret": {
          "type": "boolean",
          "description": "Create the provider DSN Secret from dsnSecretValue. Prefer external Secrets for production."
        },
        "dsnSecretValue": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "provider": {
            "properties": {
              "createDsnSecret": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "required": ["dsnSecretName", "dsnSecretValue"],
            "properties": {
              "dsnSecretName": {
                "type": "string",
                "minLength": 1
              },
              "dsnSecretValue": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
