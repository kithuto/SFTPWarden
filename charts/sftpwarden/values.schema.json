{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "runtime": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1,
          "description": "Reserved for future multi-node support. SFTPWarden v1.2 supports replicas: 1 only."
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        }
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "dsnSecretName": {
          "type": ["string", "null"]
        },
        "dsnSecretKey": {
          "type": "string",
          "minLength": 1
        },
        "createDsnSecret": {
          "type": "boolean",
          "description": "Create the provider DSN Secret from dsnSecretValue. Prefer external Secrets for production."
        },
        "dsnSecretValue": {
          "type": "string"
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "properties": {
            "size": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|k|M|G|T|P|E)?$",
              "description": "Requested storage size for the SFTP user data PersistentVolumeClaim."
            }
          }
        }
      }
    },
    "probes": {
      "type": "object",
      "properties": {
        "startup": {
          "$ref": "#/definitions/probe"
        },
        "readiness": {
          "$ref": "#/definitions/probe"
        },
        "liveness": {
          "$ref": "#/definitions/probe"
        }
      }
    }
  },
  "definitions": {
    "probe": {
      "type": "object",
      "properties": {
        "failureThreshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of consecutive failed runtime health checks before the probe fails."
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds between runtime health checks."
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Seconds before one runtime health check attempt times out."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "provider": {
            "properties": {
              "createDsnSecret": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "required": ["dsnSecretName", "dsnSecretValue"],
            "properties": {
              "dsnSecretName": {
                "type": "string",
                "minLength": 1
              },
              "dsnSecretValue": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
